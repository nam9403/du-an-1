# Sao chép thành `.env` và điền giá trị (không commit `.env`).
# Ứng dụng có thể đọc qua biến môi trường hệ thống hoặc file .env nếu bạn cấu hình load (vd. python-dotenv).

# --- LLM (tuỳ chọn; thiếu thì dùng fallback template) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GROQ_API_KEYS=gsk_key_1;gsk_key_2
# OPENAI_API_KEYS=sk_key_1;sk_key_2
# GEMINI_API_KEYS=AIza_key_1;AIza_key_2
# II_APP_SECRET_KEY=base64url_32bytes_fernet_key

# --- Định giá Graham: lợi suất trái phiếu chuẩn (%/năm), mặc định 4.4 ---
# II_DEFAULT_BOND_YIELD_PCT=4.4

# --- Timeout HTTP (giây): portal + scraper dùng chung ---
# II_HTTP_TIMEOUT=12
# VALUE_INVESTOR_SCRAPER_TIMEOUT=18

# --- API BCTC tùy chỉnh (nếu có backend riêng) ---
# VALUE_INVESTOR_FINANCIAL_API_URL=https://example.com/api/v1/financials

# --- Cảnh báo Telegram / email (có thể cấu hình trong UI) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ALERT_WEBHOOK_URL=
# ALERT_EMAIL_TO=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
